{
  "name": "openfreebooks",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "sync:chapters": "bun scripts/sync-chapters.ts",
    "sync:sponsors": "bun scripts/fetch-github-sponsors.ts",
    "generate:site-metadata": "bun scripts/generate-site-metadata.ts",
    "build:js": "bun run sync:chapters && vite build",
    "build:site": "bun run generate:site-metadata && zola build && bun run index:search",
    "build": "bun run check:static-html && bun run validate:curriculum && rm -f themes/openfreebooks/static/main.css public/main.css && bun run build:js && bun run build:site",
    "index:search": "pagefind --site public --glob \"**/index.html\" && rm -rf static/pagefind && cp -R public/pagefind static/pagefind",
    "dev:js": "bun run sync:chapters && vite build --watch",
    "dev": "bash scripts/dev.sh",
    "check:static-html": "bash scripts/check-static-html.sh",
    "scan:size": "bun scripts/scan-output-size.ts",
    "test": "bun test",
    "validate:curriculum": "bun scripts/validate-curriculum.ts"
  },
  "dependencies": {
    "defuddle": "^0.18.1",
    "katex": "^0.16.47",
    "mermaid": "^11.15.0",
    "solid-js": "^1.9.5",
    "svg-pan-zoom": "^3.6.2",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "sass": "^1.89.2",
    "pagefind": "^1.5.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-solid": "^2.11.6"
  }
}
